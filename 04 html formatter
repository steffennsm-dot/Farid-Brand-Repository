## Blog Post — HTML-Schale (vollständig, direkt verwenden)

Das folgende HTML ist die vollständige Schale für jeden Blog Post.
Platzhalter in `[GROSSBUCHSTABEN]` ersetzen. Ungenutzte Elemente komplett entfernen.

```html
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>[ARTIKEL-TITEL] | Farid El-Nomany</title>
  <meta name="description" content="[META-BESCHREIBUNG – 1 Satz, max. 155 Zeichen]">
  <style>
    /* === FARBEN === */
    :root {
      --bg:           #F4F1EC;
      --surface:      #FFFFFF;
      --ink:          #1A1A1A;
      --body:         #2C2C2C;
      --muted:        #888888;
      --accent:       #7F1710;
      --accent-light: #F4D0C8;
      --border:       #E0DAD2;
      --bg-quote:     #F9F6F2;
    }

    /* === RESET === */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { overflow-x: hidden; scroll-behavior: smooth; }

    /* === BASIS === */
    body {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 18px;
      line-height: 1.8;
      color: var(--body);
      background: var(--surface);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* === PROGRESS BAR === */
    .progress-bar {
      position: fixed;
      top: 0; left: 0;
      height: 3px;
      width: 0%;
      background: var(--accent);
      z-index: 200;
      transition: width 0.1s linear;
    }

    /* === ARTIKEL-WRAPPER === */
    .post-wrapper {
      max-width: 720px;
      margin: 0 auto;
      padding: 48px 32px 80px;
    }

    /* === META-ZEILE === */
    .post-meta {
      font-family: Helvetica Neue, Helvetica, Arial, sans-serif;
      font-size: 12px;
      font-weight: 500;
      color: var(--muted);
      letter-spacing: 0.5px;
      margin-bottom: 32px;
    }

    /* === HERO-BILD === */
    .hero-image {
      width: 100%;
      max-width: 720px;
      height: auto;
      border-radius: 4px;
      display: block;
      margin: 0 0 40px 0;
    }

    /* === TITEL === */
    .post-title {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 36px;
      font-weight: 700;
      line-height: 1.2;
      letter-spacing: -0.02em;
      color: var(--ink);
      margin-bottom: 24px;
    }

    /* === AUTOR-ZEILE === */
    .author-row {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 40px;
    }
    .author-avatar {
      width: 40px; height: 40px;
      border-radius: 50%;
      object-fit: cover;
    }
    .author-name {
      font-family: Helvetica Neue, Helvetica, Arial, sans-serif;
      font-size: 13px;
      font-weight: 600;
      color: var(--ink);
    }
    .author-date {
      font-family: Helvetica Neue, Helvetica, Arial, sans-serif;
      font-size: 12px;
      color: var(--muted);
    }

    /* === FLIESSTEXT === */
    .post-body p {
      font-size: 18px;
      line-height: 1.8;
      color: var(--body);
      margin-bottom: 22px;
    }

    /* === LEAD-PARAGRAPH === */
    .post-lead {
      font-size: 20px;
      font-weight: 600;
      line-height: 1.7;
      color: var(--body);
      border-left: 4px solid var(--accent);
      padding-left: 20px;
      margin-bottom: 40px;
    }

    /* === ÜBERSCHRIFTEN === */
    .post-body h2 {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 24px;
      font-weight: 700;
      line-height: 1.3;
      color: var(--ink);
      margin: 56px 0 20px;
      padding-top: 32px;
      border-top: 1px solid var(--border);
    }
    .post-body h2:first-of-type { border-top: none; padding-top: 0; }
    .post-body h3 {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 20px;
      font-weight: 700;
      color: var(--ink);
      margin: 36px 0 14px;
    }

    /* === PULL-QUOTE === */
    .pull-quote {
      background: var(--bg-quote);
      border-left: 5px solid var(--accent);
      padding: 24px 32px;
      margin: 40px 0;
      font-size: 21px;
      font-style: italic;
      line-height: 1.6;
      color: var(--ink);
    }
    .pull-quote p { margin: 0; font-size: 21px; }

    /* === HIGHLIGHT-BOX (für Thesen) === */
    .highlight-box {
      background: var(--bg);
      border-left: 5px solid var(--accent);
      padding: 28px 32px;
      margin: 40px 0;
    }
    .highlight-box p { margin: 0; font-size: 17px; color: var(--body); }

    /* === ZITAT-BOX (für Beispiele/Anekdoten) === */
    .example-box {
      background: var(--bg-quote);
      border: 1px solid var(--border);
      border-left: 4px solid var(--accent);
      padding: 24px 28px;
      margin: 32px 0;
    }
    .example-box p { margin: 0; font-size: 16px; line-height: 1.75; color: var(--body); }

    /* === DUNKEL-BAND (Wendepunkt) === */
    .dark-band {
      background: var(--ink);
      color: #FFFFFF;
      padding: 48px 40px;
      margin: 48px -32px;
    }
    .dark-band h2 {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 26px;
      font-weight: 700;
      color: #FFFFFF;
      margin-bottom: 20px;
      border: none;
      padding: 0;
    }
    .dark-band p {
      font-size: 18px;
      line-height: 1.8;
      color: rgba(255,255,255,0.85);
      margin-bottom: 18px;
    }
    .dark-band p:last-child { margin-bottom: 0; }

    /* === TOOLTIP-TERME === */
    .term {
      position: relative;
      border-bottom: 1.5px dotted var(--accent);
      cursor: help;
    }
    .term .tip {
      visibility: hidden;
      opacity: 0;
      position: absolute;
      bottom: calc(100% + 8px);
      left: 50%;
      transform: translateX(-50%);
      background: var(--ink);
      color: #FFFFFF;
      font-family: Helvetica Neue, Helvetica, Arial, sans-serif;
      font-size: 12px;
      font-weight: 500;
      padding: 6px 10px;
      border-radius: 3px;
      max-width: 220px;
      white-space: normal;
      line-height: 1.4;
      z-index: 10;
      pointer-events: none;
      transition: opacity 0.15s ease;
    }
    .term .tip::after {
      content: '';
      position: absolute;
      top: 100%; left: 50%;
      transform: translateX(-50%);
      border: 5px solid transparent;
      border-top-color: var(--ink);
    }
    .term:hover .tip,
    .term:focus .tip { visibility: visible; opacity: 1; }

    /* === ABSCHLUSS === */
    .post-closing {
      font-style: italic;
      font-size: 18px;
      line-height: 1.8;
      color: var(--body);
      border-top: 1px solid var(--border);
      padding-top: 32px;
      margin-top: 48px;
    }

    /* === SIGNATUR === */
    .post-signature {
      font-family: Georgia, 'Times New Roman', serif;
      font-size: 20px;
      font-weight: 700;
      color: var(--ink);
      margin-top: 24px;
    }

    /* === CTA-BOX === */
    .cta-box {
      background: var(--bg);
      border-left: 5px solid var(--accent);
      padding: 28px 32px;
      margin: 48px 0 0;
    }
    .cta-label {
      font-family: Helvetica Neue, Helvetica, Arial, sans-serif;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 10px;
    }
    .cta-text {
      font-size: 17px;
      color: var(--body);
      margin-bottom: 16px;
    }
    .cta-link {
      font-family: Helvetica Neue, Helvetica, Arial, sans-serif;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--accent);
      text-decoration: none;
    }
    .cta-link:hover { text-decoration: underline; }

    /* === RESPONSIVE === */
    @media (max-width: 680px) {
      .post-wrapper   { padding: 32px 20px 64px; }
      .post-title     { font-size: 28px; }
      .post-lead      { font-size: 18px; }
      .pull-quote     { font-size: 18px; padding: 20px 24px; }
      .pull-quote p   { font-size: 18px; }
      .dark-band      { margin: 40px -20px; padding: 40px 24px; }
      .dark-band h2   { font-size: 22px; }
      .post-body h2   { font-size: 21px; }
      .term .tip      { left: 0; transform: none; }
      .term .tip::after { left: 16px; transform: none; }
    }

    /* === PRINT === */
    @media print {
      .progress-bar { display: none; }
      .dark-band { background: #F4F1EC; color: var(--ink); margin: 40px 0; }
      .dark-band h2 { color: var(--ink); }
      .dark-band p  { color: var(--body); }
      .term { border-bottom: none; }
      .term .tip { display: none; }
      .cta-box { background: white; border: 1px solid var(--border); }
      body { font-size: 11pt; }
      a { color: var(--ink); text-decoration: none; }
    }
  </style>
